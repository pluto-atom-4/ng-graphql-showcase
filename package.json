{
  "name": "ng-graphql-playground",
  "version": "1.0.0",
  "description": "Type-safe full-stack monorepo for managing long-running manufacturing workflows",
  "scripts": {
    "prepare": "husky",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:clean": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f sql-server",
    "db:migrate": "cd backend/src/FactoryApp.WebApi && dotnet ef database update",
    "setup": "pnpm docker:up && pnpm db:migrate && echo '✅ Setup complete. Run: pnpm dev:backend & pnpm dev:frontend'",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "cd backend/src/FactoryApp.WebApi && dotnet watch run",
    "dev:frontend": "pnpm --filter frontend run ng serve",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:backend": "cd backend && dotnet build",
    "build:frontend": "pnpm --filter frontend run build",
    "test": "pnpm test:backend && pnpm test:frontend",
    "test:backend": "dotnet test ./backend/src",
    "test:frontend": "pnpm --filter frontend run test",
    "codegen": "pnpm --filter frontend run codegen",
    "lint": "pnpm --filter frontend run lint",
    "format": "pnpm --filter frontend run format",
    "design:sync": "builder sync --config .builderio/config.json",
    "design:sync-back": "figma-code-connect sync",
    "mcp:figma": "figma-mcp",
    "validate:generated-components": "node scripts/validate-generated-components.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "^3.8.3"
  },
  "keywords": [
    "manufacturing",
    "workflow",
    "graphql",
    "dotnet",
    "angular",
    "full-stack"
  ],
  "author": "Pluto Atom",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
