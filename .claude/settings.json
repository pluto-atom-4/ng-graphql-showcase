{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(npm *)",
      "Bash(dotnet *)",
      "Bash(git *)",
      "Read",
      "Edit"
    ]
  },
  "skillOverrides": {
    "fix-github-issues": "on",
    "example-skills:session-blog-to-gist": "on",
    "example-skills:push-feature-branch": "on",
    "example-skills:doc-coauthoring": "on",
    "update-config": "on",
    "secure-github-repo": "on"
  },
  "autoMemoryEnabled": true,
  "alwaysThinkingEnabled": true,
  "model": "claude-haiku-4-5-20251001",
  "modelOverride": "haiku",
  "respectGitignore": true,
  "spinnerTipsEnabled": true
}
