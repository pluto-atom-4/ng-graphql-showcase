{
  "lspServers": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    },
    "csharp": {
      "command": "dotnet",
      "args": [
        "dnx",
        "roslyn-language-server",
        "--yes",
        "--prerelease",
        "--",
        "--stdio",
        "--autoLoadProjects"
      ],
      "fileExtensions": {
        ".cs": "csharp"
      }
    }
  }
}
