{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "your-secret-key-must-be-32-chars-minimum-for-hs256-algorithm-here",
    "Issuer": "factory-app",
    "Audience": "factory-app-users",
    "ExpirationHours": 1
  },
  "GraphQL": {
    "QueryComplexity": {
      "Enabled": true,
      "MaxComplexity": 1000,
      "DefaultFieldCost": 1,
      "ListMultiplier": 10,
      "FieldCosts": {
        "Query.builds": 100,
        "Build.parts": 10,
        "Build.testRuns": 10,
        "Part.testRuns": 5
      }
    }
  }
}
