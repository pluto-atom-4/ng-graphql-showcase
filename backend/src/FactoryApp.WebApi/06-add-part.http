###
### Add part with large quantity
### Verify: supports high quantity values (e.g., 10000)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"Bulk Component\", sku: \"SKU-BULK-999\", quantity: 10000) { id quantity } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Quantity stored correctly", function() {
    client.assert(response.body.data.addPart.quantity === 10000, "Expected quantity 10000, got " + response.body.data.addPart.quantity);
  });
%}

###
### Query build with newly added parts
### Verify: parts visible via DataLoader
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name parts { id name sku quantity } } }"
}

> {%
  client.test("Parts accessible via query", function() {
    client.assert(Array.isArray(response.body.data.build.parts), "Expected parts array");
  });
%}
