@token = paste_token_from_01_authentication_here
@buildId = paste_build_id_from_02_create_build_here

###
### 06. ADD PART - Part Management & Validation
### Create parts within a build with full validation
### Note: Run 01-authentication.http then 02-create-build.http first
###

### Add part with valid inputs
### Returns PartPayload with id, buildId, name, sku, quantity
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"Precision Bearing\", sku: \"SKU-PB-001\", quantity: 5) { id buildId name sku quantity createdAt } }"
}

> {%
  client.test("HTTP 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Part ID returned", function() {
    client.assert(response.body.data.addPart.id, "Missing partId");
  });

  client.global.set("partId", response.body.data.addPart.id);
%}

###
### Add second part to same build
### Verify: multiple parts can belong to same build
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"Control Module\", sku: \"SKU-CM-042\", quantity: 2) { id buildId name sku quantity } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Part belongs to correct build", function() {
    client.assert(response.body.data.addPart.buildId === client.global.get("buildId"), "buildId mismatch");
  });
%}

###
### Add part with zero quantity
### Should return validation error (quantity must be > 0)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"Invalid Part\", sku: \"SKU-INV\", quantity: 0) { id name } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for zero quantity");
  });
%}

###
### Add part with negative quantity
### Should return validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"Negative Part\", sku: \"SKU-NEG\", quantity: -10) { id } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for negative quantity");
  });
%}

###
### Add part to non-existent build
### Should return error (foreign key constraint or validation)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"00000000-0000-0000-0000-000000000000\", name: \"Orphan Part\", sku: \"SKU-ORP\", quantity: 5) { id } }"
}

> {%
  client.test("GraphQL error for non-existent build", function() {
    client.assert(response.body.errors, "Expected error for invalid buildId");
  });
%}

###
### Add part with empty name
### Should return validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"\", sku: \"SKU-EMPTY\", quantity: 1) { id } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for empty name");
  });
%}

###
### Add part with empty SKU
### Should return validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { addPart(buildId: \"{{buildId}}\", name: \"No SKU Part\", sku: \"\", quantity: 1) { id } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for empty SKU");
  });
