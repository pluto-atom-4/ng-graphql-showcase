@token = paste_token_from_01_authentication_here

###
### 08. ERROR CASES & MALFORMED QUERIES
### GraphQL syntax errors, missing fields, invalid input, and edge cases
### Test error response format and error codes
###

### Missing required argument in mutation
### Should return GraphQL parse error (missing argument: name)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(description: \"Missing name argument\") { id } }"
}

> {%
  client.test("GraphQL error present", function() {
    client.assert(response.body.errors, "Expected GraphQL error for missing argument");
  });
%}

###
### Invalid GraphQL syntax - unmatched brace
### Should return parse error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Test\") { id name } }"
}

> {%
  client.test("GraphQL parse error", function() {
    client.assert(response.body.errors, "Expected parse error");
  });
%}

###
### Requesting non-existent field
### Should return GraphQL validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"123\") { id name nonExistentField } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for non-existent field");
  });
%}

###
### Using wrong type for argument
### Expected: Int, Got: String
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { builds(limit: \"not-a-number\", offset: 0) { items { id } } }"
}

> {%
  client.test("GraphQL type error", function() {
    client.assert(response.body.errors, "Expected type error");
  });
%}

###
### Empty query body
### Should return parse error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": ""
}

> {%
  client.test("GraphQL error for empty query", function() {
    client.assert(response.body.errors, "Expected error for empty query");
  });
%}

###
### Malformed JSON (missing closing brace)
### Should return HTTP 400 or JSON parse error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Test\") { id }"
}

> {%
  client.test("Malformed query error", function() {
    client.assert(response.body.errors, "Expected error for malformed query");
  });
%}

###
### No authorization header (if required)
### Should return 401 Unauthorized or GraphQL auth error
POST {{graphqlUrl}}
Content-Type: application/json

{
  "query": "mutation { createBuild(name: \"Unauthorized\", description: \"No token\") { id } }"
}

> {%
  client.test("Auth error or rejection", function() {
    client.assert(response.status === 401 || response.body.errors, "Expected auth error");
  });
%}

###
### Invalid token format
### Bearer token with invalid value
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer invalid.token.format

{
  "query": "mutation { createBuild(name: \"Test\", description: null) { id } }"
}

> {%
  client.test("Invalid token rejected", function() {
    client.assert(response.status === 401 || response.body.errors, "Expected token validation error");
  });
%}

###
### Request to non-existent endpoint
### Should return 404 Not Found
POST {{baseUrl}}/graphql-not-found
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"123\") { id } }"
}

> {%
  client.test("404 for non-existent endpoint", function() {
    client.assert(response.status === 404, "Expected 404, got " + response.status);
  });
%}

###
### Invalid enum value
### BuildStatus enum doesn't have INVALID value
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { updateBuildStatus(id: \"123\", status: INVALID_STATUS) { id } }"
}

> {%
  client.test("GraphQL enum validation error", function() {
    client.assert(response.body.errors, "Expected enum validation error");
  });
%}

###
### Null when non-null expected
### buildId is required (non-null), cannot pass null
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { updateBuildStatus(id: null, status: RUNNING) { id } }"
}

> {%
  client.test("GraphQL non-null constraint error", function() {
    client.assert(response.body.errors, "Expected non-null constraint error");
  });
%}

###
### Query timeout scenario (intentionally deep nesting)
### Tests server's depth limit (max 5 levels per CLAUDE.md)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { builds(limit: 10, offset: 0) { items { id parts { id name testRuns { id status result fileUrl { url { domain { name { value } } } } } } } } }"
}

> {%
  client.test("Depth limit enforced", function() {
    client.assert(response.body.errors, "Expected depth limit error");
  });
%}

###
### Check error response format
### Successful error response should contain: errors array with message and extensions
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"\") { id } }"
}

> {%
  client.test("Error response format", function() {
    client.assert(response.body.errors && Array.isArray(response.body.errors), "Expected errors array");
    if (response.body.errors.length > 0) {
      client.assert(response.body.errors[0].message, "Expected error message");
    }
  });
%}
