@token = paste_token_from_01_authentication_here
@buildId = 10000000-0000-0000-0000-000000000006

###
### 04. QUERY BUILD WITH RELATIONS - DataLoader Verification
### Test nested parts and testRuns to verify DataLoader batch loading (N+1 prevention)
### Note: Run 01-authentication.http then 02-create-build.http first
###

### Query build with nested parts
### Verify: parts loaded via DataLoader (should be 1 build query + 1 batch parts query = 2 total)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name parts { id name sku quantity createdAt } } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Parts array present", function() {
    client.assert(Array.isArray(response.body.data.build.parts), "Expected parts array");
  });

  client.test("DataLoader batching verified (queryCount = 2)", function() {
    var queryCount = response.body.extensions?.queryCount;
    client.assert(queryCount !== undefined, "Missing queryCount in extensions");
    client.assert(queryCount === 2,
      "Expected 2 queries (1 build + 1 batch parts), got " + queryCount);
  });
%}

###
### Query build with nested testRuns
### Verify: testRuns loaded via DataLoader batch loading (1 build + 1 batch testRuns = 2 total)
POST {{graphqlUrl}}
Content-Type: application/json
