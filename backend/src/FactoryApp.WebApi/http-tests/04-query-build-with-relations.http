@token = paste_token_from_01_authentication_here
@buildId = paste_build_id_from_02_create_build_here

###
### 04. QUERY BUILD WITH RELATIONS - DataLoader Verification
### Test nested parts and testRuns to verify DataLoader batch loading (N+1 prevention)
### Note: Run 01-authentication.http then 02-create-build.http first
###

### Query build with nested parts
### Verify: parts loaded via DataLoader (should be 1 build query + 1 batch parts query)
### Check backend logs to confirm no N+1 queries
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name parts { id name sku quantity createdAt } } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Parts array present", function() {
    client.assert(Array.isArray(response.body.data.build.parts), "Expected parts array");
  });
%}

###
### Query build with nested testRuns
### Verify: testRuns loaded via DataLoader batch loading
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name testRuns { id status result fileUrl completedAt createdAt } } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("TestRuns array present", function() {
    client.assert(Array.isArray(response.body.data.build.testRuns), "Expected testRuns array");
  });
%}

###
### Query build with both parts and testRuns in single query
### Verify: both nested entities loaded efficiently
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name status parts { id name sku quantity } testRuns { id status result } } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Both relations present", function() {
    client.assert(Array.isArray(response.body.data.build.parts), "Expected parts array");
    client.assert(Array.isArray(response.body.data.build.testRuns), "Expected testRuns array");
  });
%}

###
### Query multiple builds to test DataLoader batching
### All parts should be batch-loaded in single query (not N builds * 1 query per build)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { builds(limit: 10, offset: 0) { items { id name parts { id name sku } testRuns { id status } } totalCount } }"
}

> {%
  client.test("Batch loading verified", function() {
    client.assert(response.body.data.builds.items.length > 0, "Expected builds");
    response.body.data.builds.items.forEach(function(build) {
      client.assert(Array.isArray(build.parts), "Expected parts array for build");
      client.assert(Array.isArray(build.testRuns), "Expected testRuns array for build");
    });
  });
%}

###
### Compare: Query build without relations (baseline for performance comparison)
### Use this response time as baseline; nested query should take similar time with DataLoader
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name status } }"
}

> {%
  client.test("Baseline query successful", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
    client.assert(response.body.data.build, "Expected build data");
  });
%}

###
### Query parts with all fields
### Verify Part schema: id, buildId, name, sku, quantity, createdAt
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id parts { id buildId name sku quantity createdAt } } }"
}

> {%
  client.test("Part fields present", function() {
    if (response.body.data.build.parts.length > 0) {
      var part = response.body.data.build.parts[0];
      client.assert(part.id, "Missing part id");
      client.assert(part.buildId, "Missing buildId");
      client.assert(part.name, "Missing name");
      client.assert(part.sku, "Missing sku");
      client.assert(typeof part.quantity === "number", "Missing/invalid quantity");
    }
  });
%}

###
### Query testRuns with all fields
### Verify TestRun schema: id, buildId, status, result, fileUrl, completedAt, createdAt, updatedAt
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id testRuns { id buildId status result fileUrl completedAt createdAt updatedAt } } }"
}

> {%
  client.test("TestRun fields present", function() {
    if (response.body.data.build.testRuns.length > 0) {
      var testRun = response.body.data.build.testRuns[0];
      client.assert(testRun.id, "Missing testRun id");
      client.assert(testRun.buildId, "Missing buildId");
      client.assert(testRun.status, "Missing status");
    }
  });
%}
