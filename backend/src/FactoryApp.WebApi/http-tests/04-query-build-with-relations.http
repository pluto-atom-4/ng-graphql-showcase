%}

###
### Query build with both parts and testRuns in single query
### Verify: both nested entities loaded efficiently (1 build + 1 batch parts + 1 batch testRuns = 3 total)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name status parts { id name sku quantity } testRuns { id status result } } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Both relations present", function() {
    client.assert(Array.isArray(response.body.data.build.parts), "Expected parts array");
    client.assert(Array.isArray(response.body.data.build.testRuns), "Expected testRuns array");
  });

  client.test("DataLoader batching verified (queryCount = 3)", function() {
    var queryCount = response.body.extensions?.queryCount;
    client.assert(queryCount !== undefined, "Missing queryCount in extensions");
    client.assert(queryCount === 3,
      "Expected 3 queries (1 build + 1 batch parts + 1 batch testRuns), got " + queryCount);
  });
%}

###
### Query multiple builds to test DataLoader batching
### Critical N+1 test: 10 builds should use 3 queries (1 builds + 1 batch parts + 1 batch testRuns)
### NOT 10 builds * 1 part query per build = 20+ queries (N+1 failure)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 10, offset: 0) { items { id name parts { id name sku } testRuns { id status } } totalCount } }"
}

> {%
  client.test("Batch loading verified", function() {
    client.assert(response.body.data.buildsPaginated.items.length > 0, "Expected builds");
    response.body.data.buildsPaginated.items.forEach(function(build) {
      client.assert(Array.isArray(build.parts), "Expected parts array for build");
      client.assert(Array.isArray(build.testRuns), "Expected testRuns array for build");
    });
  });

  client.test("No N+1 queries (queryCount ≤ 3)", function() {
    var queryCount = response.body.extensions?.queryCount;
    var buildCount = response.body.data.buildsPaginated.items.length;
    client.assert(queryCount !== undefined, "Missing queryCount in extensions");
    client.assert(queryCount <= 3,
      "N+1 detected: " + queryCount + " queries for " + buildCount + " builds (expected ≤3)");
  });
%}

###
### Compare: Query build without relations (baseline for performance comparison)
### Use this response time + query count as baseline; nested query should have similar metrics with DataLoader
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name status } }"
}

> {%
  client.test("Baseline query successful", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
    client.assert(response.body.data.build, "Expected build data");
  });

  client.test("Baseline query count = 1", function() {
    var queryCount = response.body.extensions?.queryCount;
    client.assert(queryCount !== undefined, "Missing queryCount in extensions");
    client.assert(queryCount === 1,
      "Expected 1 query (simple build lookup), got " + queryCount);

    // Store baseline for comparison
    client.global.set("baselineQueryTime", response.body.extensions.responseTimeMs);
  });
%}

###
### Query parts with all fields
### Verify Part schema: id, buildId, name, sku, quantity, createdAt
### Also verify DataLoader batching (1 build + 1 batch parts = 2 queries)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id parts { id buildId name sku quantity createdAt } } }"
}

> {%
  client.test("Part fields present", function() {
    if (response.body.data.build.parts.length > 0) {
      var part = response.body.data.build.parts[0];
      client.assert(part.id, "Missing part id");
      client.assert(part.buildId, "Missing buildId");
      client.assert(part.name, "Missing name");
      client.assert(part.sku, "Missing sku");
      client.assert(typeof part.quantity === "number", "Missing/invalid quantity");
    }
  });

  client.test("DataLoader batching verified (queryCount = 2)", function() {
    var queryCount = response.body.extensions?.queryCount;
    client.assert(queryCount !== undefined, "Missing queryCount in extensions");
    client.assert(queryCount === 2,
      "Expected 2 queries (1 build + 1 batch parts), got " + queryCount);
  });
%}

