###
### Verify precision not truncated (0.5 not rounded to 0 or 1)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 1, offset: 0) { items { id parts { sku quantity } } } }"
}

> {%
  client.test("Precision not truncated", function() {
    var build = response.body.data.buildsPaginated.items[0];
    var parts = build.parts;

    // Find fractional quantity parts
    var hasHalf = parts.some(p => p.quantity === 0.5);
    var hasOneAndHalf = parts.some(p => p.quantity === 1.5);
    var hasDecimal = parts.some(p => p.quantity === 2.75);

    client.assert(hasHalf || hasOneAndHalf || hasDecimal, "No decimal quantities found - precision may be truncated");
  });

  client.log("✓ Precision preserved across queries");
%}
