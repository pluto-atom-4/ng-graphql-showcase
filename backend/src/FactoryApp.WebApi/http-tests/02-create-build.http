@token = paste_token_from_01_authentication_here

###
### 02. CREATE BUILD WORKFLOWS
### Build creation with validation scenarios
### Note: Run 01-authentication.http first to set @token variable
###

### Create build with valid name and description
### Returns BuildPayload with id, name, description, status
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Manufacturing Build A\", description: \"High-volume production run for Q2 2026\") { id name description status createdAt updatedAt } }"
}

> {%
  client.test("HTTP 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Build ID returned", function() {
    client.assert(response.body.data.createBuild.id, "Missing buildId");
  });

  client.global.set("buildId", response.body.data.createBuild.id);
%}

###
### Create build with valid name, no description
### Description is optional
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Quick Build B\") { id name description status } }"
}

> {%
  client.test("HTTP 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });
%}

###
### Create build with empty name
### Should return GraphQL validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"\", description: \"Description without name\") { id name } }"
}

> {%
  client.test("GraphQL validation error present", function() {
    client.assert(response.body.errors, "Expected validation error for empty name");
  });
%}

###
### Create build with name exceeding 256 characters
### Should return validation error (max length: 256)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\", description: \"Too long name\") { id name } }"
}

> {%
  client.test("GraphQL validation error present", function() {
    client.assert(response.body.errors, "Expected validation error for name > 256");
  });
%}

###
### Create build with description exceeding 1000 characters
### Should return validation error (max length: 1000)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Valid Name\", description: \"Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua Ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur Excepteur sint occaecat cupidatat non proident sunt in culpa qui officia deserunt mollit anim id est laborum Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua Ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur Excepteur sint occaecat cupidatat non proident sunt in culpa qui officia deserunt mollit anim id est laborum Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliquua extra\") { id } }"
}

> {%
  client.test("GraphQL validation error present", function() {
    client.assert(response.body.errors, "Expected validation error for description > 1000");
  });
%}

###
### Build status after creation
### Default status is PENDING
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Status Check Build\", description: \"Verifying default status\") { id status } }"
}

> {%
  client.test("Default status is Pending", function() {
    client.assert(response.body.data.createBuild.status === "Pending", "Expected Pending status, got " + response.body.data.createBuild.status);
  });
%}

###
### Create build with NULL description (optional field)
### Should succeed - description is nullable
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Build with Null Description\", description: null) { id name description } }"
}

> {%
  client.test("NULL description accepted", function() {
    client.assert(!response.body.errors, "Expected success with NULL description, got errors: " + JSON.stringify(response.body.errors));
  });

  client.test("NULL description preserved", function() {
    client.assert(response.body.data.createBuild.description === null, "Expected null description, got " + response.body.data.createBuild.description);
  });
%}

###
### Create build with emoji in name
### UTF-8 support: factory emoji 🏭 wrench 🔧 gear ⚙️
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Factory Build 🏭🔧⚙️ Q2 2026\", description: \"Production run with emoji support\") { id name } }"
}

> {%
  client.test("Emoji in name accepted", function() {
    client.assert(!response.body.errors, "Expected success with emoji in name");
  });

  client.test("Emoji preserved in response", function() {
    var name = response.body.data.createBuild.name;
    client.assert(name.includes("🏭"), "Expected factory emoji preserved, got: " + name);
    client.assert(name.includes("🔧"), "Expected wrench emoji preserved");
    client.assert(name.includes("⚙️"), "Expected gear emoji preserved");
  });
%}

###
### Create build with unicode characters (multi-language)
### Chinese 制造, Japanese 日本語, Korean 한국어, Russian Русский, Arabic العربية
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"制造 Manufacturing 製造\", description: \"Multi-language: 日本語 한국어 Русский العربية\") { id name description } }"
}

> {%
  client.test("Unicode characters accepted", function() {
    client.assert(!response.body.errors, "Expected success with unicode characters");
  });

  client.test("Unicode preserved in database", function() {
    var name = response.body.data.createBuild.name;
    client.assert(name.includes("制造"), "Expected Chinese preserved");
    client.assert(name.includes("製造"), "Expected Japanese preserved");
  });
%}
