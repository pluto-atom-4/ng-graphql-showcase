@token = paste_token_from_01_authentication_here
@buildId = 10000000-0000-0000-0000-000000000001

###
### 03. QUERY BUILDS - PAGINATION & FILTERING
### Single build queries and paginated list queries
### Note: Run 01-authentication.http then 02-create-build.http first
###

### Query single build by ID with all fields
### Verify: id, name, description, status, createdAt, updatedAt present
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"{{buildId}}\") { id name description status createdAt updatedAt } }"
}

> {%
  client.test("HTTP 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Build fields present", function() {
    client.assert(response.body.data.build.id, "Missing buildId");
    client.assert(response.body.data.build.name, "Missing name");
    client.assert(response.body.data.build.status, "Missing status");
  });
%}

###
### Query single build with invalid ID
### Should return null (build not found)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"00000000-0000-0000-0000-000000000000\") { id name } }"
}

> {%
  client.test("No GraphQL errors", function() {
    client.assert(!response.body.errors, "GraphQL errors: " + JSON.stringify(response.body.errors));
  });

  client.test("Build is null", function() {
    client.assert(response.body.data.build === null, "Expected null for invalid ID");
  });
%}

###
### Query paginated builds - first page
### Verify: items array, totalCount, hasNextPage, hasPreviousPage
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 10, offset: 0) { items { id name status } totalCount hasNextPage hasPreviousPage } }"
}

> {%
  client.test("HTTP 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });

  client.test("Pagination fields present", function() {
    client.assert(response.body.data.buildsPaginated.items, "Missing items array");
    client.assert(typeof response.body.data.buildsPaginated.totalCount === "number", "Missing totalCount");
    client.assert(typeof response.body.data.buildsPaginated.hasNextPage === "boolean", "Missing hasNextPage");
    client.assert(typeof response.body.data.buildsPaginated.hasPreviousPage === "boolean", "Missing hasPreviousPage");
  });
%}

###
### Query paginated builds - second page
### offset=10 should skip first 10 items
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 10, offset: 10) { items { id name } totalCount hasNextPage hasPreviousPage } }"
}

> {%
  client.test("Pagination offset applied", function() {
    client.assert(typeof response.body.data.buildsPaginated.hasPreviousPage === "boolean", "Missing hasPreviousPage");
  });
%}

###
### Query with small page size
### Verify pagination logic with limit=5
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 5, offset: 0) { items { id name } totalCount hasNextPage } }"
}

> {%
  client.test("Limit applied correctly", function() {
    client.assert(response.body.data.buildsPaginated.items.length <= 5, "Expected <= 5 items, got " + response.body.data.buildsPaginated.items.length);
  });
%}

###
### Query builds with invalid limit (negative)
### Should return GraphQL validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: -1, offset: 0) { items { id } } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for negative limit");
  });
%}

###
### Query builds with invalid offset (negative)
### Should return GraphQL validation error
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 10, offset: -1) { items { id } } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for negative offset");
  });
%}

###
### Query builds with limit exceeding maximum (1001)
### Should return validation error (max limit: 1000)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 1001, offset: 0) { items { id } } }"
}

> {%
  client.test("GraphQL validation error", function() {
    client.assert(response.body.errors, "Expected validation error for limit > 1000");
  });
%}

###
### Empty result query
### Query with high offset to verify empty pagination response
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { buildsPaginated(limit: 10, offset: 10000) { items { id } totalCount hasNextPage } }"
}

> {%
  client.test("Empty result handling", function() {
    client.assert(Array.isArray(response.body.data.buildsPaginated.items), "Expected items array");
  });
%}
