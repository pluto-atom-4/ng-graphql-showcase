###
### Query timeout scenario (intentionally deep nesting)
### Tests server's depth limit (max 5 levels per CLAUDE.md)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { builds(limit: 10, offset: 0) { items { id parts { id name testRuns { id status result fileUrl { url { domain { name { value } } } } } } } } }"
}

> {%
  client.test("Depth limit enforced", function() {
    client.assert(response.body.errors, "Expected depth limit error");
  });
%}

###
### Check error response format
### Successful error response should contain: errors array with message and extensions
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { build(id: \"\") { id } }"
}

> {%
  client.test("Error response format", function() {
    client.assert(response.body.errors && Array.isArray(response.body.errors), "Expected errors array");
    if (response.body.errors.length > 0) {
      client.assert(response.body.errors[0].message, "Expected error message");
    }
  });
%}

###
### CONCURRENT MUTATIONS TEST
### Verify no deadlock when multiple mutations execute
### Test 1: Create build
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { createBuild(name: \"Concurrent Build 1\", description: \"Parallel test 1\") { id } }"
}

> {%
  client.test("Concurrent mutation 1 succeeds", function() {
    client.assert(!response.body.errors, "First concurrent mutation failed: " + JSON.stringify(response.body.errors));
  });

  client.global.set("concurrentBuildId1", response.body.data.createBuild.id);
%}

###
### Concurrent mutation 2: Update status (different build)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { updateBuildStatus(id: \"10000000-0000-0000-0000-000000000001\", status: RUNNING) { id status } }"
}

> {%
  client.test("Concurrent mutation 2 succeeds", function() {
    client.assert(!response.body.errors, "Second concurrent mutation failed: " + JSON.stringify(response.body.errors));
  });
%}

###
### Verify data integrity after concurrent mutations
### Both operations should be persisted (no lost updates)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { builds(limit: 10, offset: 0) { items { id status } totalCount } }"
}

> {%
  var count = response.body.data.builds.totalCount;
  client.test("Data integrity after concurrent ops", function() {
    client.assert(count >= 2, "Expected at least 2 builds after concurrent mutations, got " + count);
  });

  client.log("✓ No deadlock detected, " + count + " builds accessible");
%}

###
### SQL INJECTION PROTECTION TEST
### Submit test run with SQL injection attempt in result field
### Result contains: '; DROP TABLE parts; --
### Should be safely stored (parameterized queries protect)
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { submitTestRun(buildId: \"10000000-0000-0000-0000-000000000001\", status: PASSED, result: \"Test passed'; DROP TABLE parts; --\", fileUrl: null) { id status result } }"
}

> {%
  client.test("SQL injection safely handled", function() {
    client.assert(!response.body.errors, "Mutation should succeed (payload is sanitized)");
  });

  client.test("Malicious payload stored verbatim", function() {
    var result = response.body.data.submitTestRun.result;
    client.assert(result === "Test passed'; DROP TABLE parts; --", "Payload should be stored as-is, not executed");
    client.log("✓ SQL injection attempt safely neutralized (EF Core parameterized queries)");
  });
%}

###
### SQL injection in buildId parameter
### UUID validation should reject malformed input
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "mutation { submitTestRun(buildId: \"123 OR 1=1\", status: PASSED, result: \"Attack\", fileUrl: null) { id } }"
}

> {%
  client.test("Malformed buildId rejected", function() {
    client.assert(response.body.errors, "Expected validation error for non-UUID buildId");
  });

  var error = response.body.errors?.[0]?.message || "unknown";
  client.log("ℹ Rejection reason: " + error);
%}

###
### RATE LIMITING BASELINE TEST
### Documents expected behavior under load
### Backend configured: 100 events/sec max
POST {{graphqlUrl}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "query": "query { builds(limit: 1, offset: 0) { totalCount } }"
}

> {%
  var httpStatus = response.status;
  client.test("Rate limit check point", function() {
    client.assert(httpStatus === 200 || httpStatus === 429, "Unexpected status: " + httpStatus);
  });

  if (httpStatus === 429) {
    client.log("⚠ Rate limit hit (429 Too Many Requests) - expected under load");
  } else {
    client.log("ℹ Request accepted (HTTP " + httpStatus + ") - within rate limit");
  }
%}
